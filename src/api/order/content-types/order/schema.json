{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "clientName": {
      "type": "string"
    },
    "clientPhone": {
      "type": "string"
    },
    "total": {
      "type": "decimal"
    },
    "orderDetails": {
      "type": "text"
    },
    "deliveryAddress": {
      "type": "string"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "Нове",
        "В обробці",
        "Відправлено",
        "Виконано"
      ],
      "default": "Нове"
    }
  }
}
