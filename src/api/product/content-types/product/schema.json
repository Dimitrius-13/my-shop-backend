  "Lenovo", "ASUS", "Acer", "Dell", "HP", "MSI", "Gigabyte", "Razer", "Microsoft", "Framework",
  "Nintendo", "Valve", "Logitech", "Corsair", "SteelSeries", "HyperX",
  "LG", "TCL", "Philips", "Panasonic", "Hisense", "BenQ", "AOC",
  "JBL", "Marshall", "Bose", "Sennheiser", "Audio-Technica", "Edifier",
  "TP-Link", "Ubiquiti", "Garmin", "DJI", "GoPro"
]
